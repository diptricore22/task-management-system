# ============================================
# ENVIRONMENT CONFIGURATION GUIDE
# ============================================
# This project uses SEPARATE environment files for Frontend and Backend
#
# Copy the appropriate .env.example file to .env in each app:
#
# 1. Frontend (Next.js)
#    cp apps/web/.env.example apps/web/.env
#
# 2. Backend (Express.js)
#    cp apps/api/.env.example apps/api/.env
#
# Then edit each .env file with your actual values

# ============================================
# FRONTEND ENVIRONMENT (.env in apps/web/)
# ============================================
# See: apps/web/.env.example

NEXT_PUBLIC_API_URL="http://localhost:3003"
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_ENABLE_EMAIL_NOTIFICATIONS="true"
NEXT_PUBLIC_ENABLE_REGISTRATION="false"

# ============================================
# BACKEND ENVIRONMENT (.env in apps/api/)
# ============================================
# See: apps/api/.env.example

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/task_management_db"
DIRECT_URL="postgresql://username:password@localhost:5432/task_management_db"

# JWT (min 32 characters)
JWT_SECRET="your-super-secure-jwt-secret-key-at-least-32-characters"
JWT_REFRESH_SECRET="your-super-secure-refresh-token-secret-key-at-least-32-characters"

# Email
RESEND_API_KEY="re_your_resend_api_key_here"
EMAIL_FROM="noreply@yourdomain.com"
SMTP_HOST="localhost"
SMTP_PORT="1025"

# Application
NODE_ENV="development"
API_PORT="3003"
API_BASE_URL="http://localhost:3003"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextjs-secret-key-at-least-32-characters"

# Security
BCRYPT_ROUNDS="12"
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX="100"

# Feature Flags
ENABLE_EMAIL_NOTIFICATIONS="true"
ENABLE_REGISTRATION="false"
