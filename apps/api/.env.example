# ============================================
# BACKEND (Express.js) ENVIRONMENT VARIABLES
# ============================================
# Location: apps/api/
# These are server-side only - NEVER expose these to browser

# ========= Database Configuration =========
DATABASE_URL="postgresql://username:password@localhost:5432/task_management_db"
DIRECT_URL="postgresql://username:password@localhost:5432/task_management_db"

# ========= JWT Configuration (REQUIRED) =========
# Minimum 32 characters for security
JWT_SECRET="your-super-secure-jwt-secret-key-at-least-32-characters"
JWT_REFRESH_SECRET="your-super-secure-refresh-token-secret-key-at-least-32-characters"

# ========= Email Configuration - Production (Resend) =========
# Only required if ENABLE_EMAIL_NOTIFICATIONS=true in production
RESEND_API_KEY="re_your_resend_api_key_here"
EMAIL_FROM="noreply@yourdomain.com"

# ========= Email Configuration - Development (SMTP) =========
# For local testing with MailHog or similar
SMTP_HOST="localhost"
SMTP_PORT="1025"

# ========= Application Configuration =========
NODE_ENV="development"
API_PORT="3003"
API_BASE_URL="http://localhost:3003"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextjs-secret-key-at-least-32-characters"

# ========= Security Configuration =========
# Password hashing rounds (10-12 recommended, more = slower but more secure)
BCRYPT_ROUNDS="12"

# Rate limiting: 900000ms = 15 minutes
RATE_LIMIT_WINDOW_MS="900000"
# Max requests per window
RATE_LIMIT_MAX="100"

# ========= Feature Flags =========
ENABLE_EMAIL_NOTIFICATIONS="true"
ENABLE_REGISTRATION="false"

# ========= Development/Testing (Optional) =========
# Uncomment these for development/testing purposes
# DEV_ADMIN_EMAIL="admin@test.com"
# DEV_ADMIN_PASSWORD="admin123"

# ========= Production Only (Optional) =========
# Uncomment and set these for production deployment
# CORS_ORIGIN="https://yourdomain.com"
# TRUST_PROXY="1"
